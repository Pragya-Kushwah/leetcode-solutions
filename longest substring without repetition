class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        unordered_map<char, int> freq;

        int left = 0;
        int maxLen = 0;

        for (int right = 0; right < s.size(); right++) {
            char ch = s[right];
            freq[ch]++;

            // window becomes invalid if character repeats
            while (freq[ch] > 1) {
                freq[s[left]]--;
                left++;
            }

            maxLen = max(maxLen, right - left + 1);
        }

        return maxLen;
    }
};
