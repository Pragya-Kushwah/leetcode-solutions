class Solution {
public:
    vector<int> findDisappearedNumbers(vector<int>& nums) {
        vector<int>disappearedNums;
        for(int i=1;i<=nums.size();i++){
            bool found = false;
            for(int j=0;j<nums.size();j++){
                if(nums[j]==i){
                 found = true;
                    break;
                }
            }
            if(found==false){
disappearedNums.push_back(i);
        }
        }
return disappearedNums;
    }
};
