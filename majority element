class Solution {
public:
    int majorityElement(vector<int>& nums) {
       int count=0;
       int candidateElement=0;
       for(int i=0;i<nums.size();i++) {
        if(count==0){
            candidateElement=nums[i];
        }
        if(nums[i]==candidateElement){
            count++;
        }
        else{
            count--;
        }
       }
       return candidateElement;
    }
};
