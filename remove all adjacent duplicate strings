class Solution {
public:
    string removeDuplicates(string s) {
      stack<char>st;   
      for(int i=0;i<s.length();i++){
        char ch=s[i];
        if(!st.empty()&& ch==st.top()){
            st.pop();
        }
        else{
            st.push(ch);
        }
      }
        string result="";
        while(!st.empty()){
            result+=st.top();
            st.pop();
        }
        reverse(result.begin(),result.end());
       return result;
      }
};
