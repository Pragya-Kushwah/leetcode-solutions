class Solution {
public:
    string makeGood(string s) {
      stack<char>st;
      for(int i=0;i<s.length();i++){
        char ch=s[i];
        if(!st.empty()&& tolower(ch)==tolower(st.top())&&ch!=st.top()){
            st.pop();
        }
        else{
            st.push(ch);
        }
      } 
      string result="";
      while(!st.empty()){
        result+=st.top();
        st.pop();
      } 
      reverse(result.begin(),result.end());
      return result;
    }
};
